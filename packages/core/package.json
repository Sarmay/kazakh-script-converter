{
  "name": "@sarmay/kaz-converter",
  "version": "0.1.1",
  "description": "Lightweight Kazakh Arabic/Cyrillic script converter for web and Node.js.",
  "author": {
    "name": "sarmay",
    "url": "https://github.com/Sarmay"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sarmay/kazakh-script-converter.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Sarmay/kazakh-script-converter/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Sarmay/kazakh-script-converter/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "kazakh",
    "cyrillic",
    "arabic",
    "tote-zhazu",
    "transliteration",
    "converter"
  ],
  "license": "MIT"
}
