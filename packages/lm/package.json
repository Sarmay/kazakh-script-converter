{
  "name": "@sarmay/kaz-converter-lm",
  "version": "0.1.1",
  "description": "Node.js LM and ONNX helpers for @sarmay/kaz-converter.",
  "author": {
    "name": "sarmay",
    "url": "https://github.com/Sarmay"
  },
  "type": "module",
  "bin": {
    "sarmay-kaz-download": "./bin/download-model.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sarmay/kazakh-script-converter.git",
    "directory": "packages/lm"
  },
  "homepage": "https://github.com/Sarmay/kazakh-script-converter/tree/main/packages/lm#readme",
  "bugs": {
    "url": "https://github.com/Sarmay/kazakh-script-converter/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external @sarmay/kaz-converter --external onnxruntime-node --external @huggingface/tokenizers",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@sarmay/kaz-converter": "^0.1.0",
    "onnxruntime-node": "^1.24.3"
  },
  "keywords": [
    "kazakh",
    "cyrillic",
    "arabic",
    "onnx",
    "language-model",
    "disambiguation"
  ],
  "license": "MIT"
}
